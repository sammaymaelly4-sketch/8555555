import { useNavigate } from 'react-router-dom'
import { CATEGORIAS, getDestaques, getPorCategoria, formatPreco } from '../lib/catalog'
import { useCart } from '../lib/cart'
import ProductCard from '../components/ProductCard'
import BottomNav from '../components/BottomNav'

export default function Home() {
  const nav = useNavigate()
  const { count } = useCart()
  const destaques = getDestaques().slice(0, 6)
  const rapidos   = getPorCategoria('bebidas').slice(0, 4)

  return (
    <div style={{ display:'flex', flexDirection:'column', minHeight:'100vh', background:'#FAF6EE' }}>
      {/* topbar */}
      <div style={{ background:'#2D5A3D', padding:'12px 14px 10px', position:'sticky', top:0, zIndex:20 }}>
        <div style={{ display:'flex', alignItems:'center', justifyContent:'space-between', marginBottom:10 }}>
          <div>
            <div style={{ fontFamily:"'Fredoka One',cursive", fontSize:17, color:'#F0E8D8', lineHeight:1 }}>Mercadinho da Carmen</div>
            <div style={{ fontSize:9, color:'#C4A882', fontWeight:700, letterSpacing:'.08em', textTransform:'uppercase' }}>📍 Vila São José · Taubaté</div>
          </div>
          <div style={{ display:'flex', gap:8 }}>
            <button onClick={() => nav('/perfil')} style={{ width:30, height:30, borderRadius:'50%', background:'rgba(255,255,255,.13)', border:'none', color:'#fff', fontSize:14, cursor:'pointer' }}>👤</button>
            <button onClick={() => nav('/carrinho')} style={{ width:30, height:30, borderRadius:'50%', background:'#E8622A', border:'none', color:'#fff', fontSize:14, cursor:'pointer', position:'relative' }}>
              🛒{count > 0 && <span style={{ position:'absolute', top:-3, right:-3, width:14, height:14, background:'#fff', borderRadius:'50%', fontSize:8, color:'#E8622A', display:'flex', alignItems:'center', justifyContent:'center', fontWeight:900 }}>{count}</span>}
            </button>
          </div>
        </div>
        <div style={{ display:'flex', alignItems:'center', gap:8, background:'rgba(255,255,255,.13)', borderRadius:18, padding:'6px 12px' }}>
          <span style={{ fontSize:13 }}>🔍</span>
          <input readOnly placeholder="O que você precisa hoje?" style={{ background:'none', border:'none', outline:'none', color:'#fff', fontFamily:"'Nunito',sans-serif", fontSize:12, fontWeight:700, width:'100%' }} />
        </div>
      </div>

      {/* hero */}
      <div style={{ background:'#1E3D2A', padding:'14px 14px 20px', display:'flex', alignItems:'flex-end', justifyContent:'space-between', position:'relative', overflow:'hidden' }}>
        <div style={{ position:'absolute', bottom:0, left:0, right:0, height:16, background:'#FAF6EE', borderRadius:'14px 14px 0 0' }} />
        <div style={{ zIndex:1, paddingBottom:20 }}>
          <div style={{ fontFamily:"'Fredoka One',cursive", fontSize:20, color:'#fff', lineHeight:1.15 }}>
            Chegou em<br/><span style={{ color:'#E8622A' }}>20 minutos!</span>
          </div>
          <div style={{ fontSize:10, color:'#C4A882', fontWeight:700, marginTop:4 }}>Entregas rápidas para o seu bairro.</div>
          <div style={{ background:'#E8622A', color:'#fff', fontSize:9, fontWeight:900, padding:'3px 10px', borderRadius:99, display:'inline-block', marginTop:8, letterSpacing:'.06em' }}>⚡ FRETE GRÁTIS HOJE</div>
        </div>
        <div style={{ fontSize:52, zIndex:1, paddingBottom:10 }}>🛵</div>
      </div>

      <div style={{ flex:1, overflowY:'auto' }}>
        {/* categorias */}
        <div style={{ padding:'14px 14px 0' }}>
          <div style={{ display:'flex', gap:10, overflowX:'auto', paddingBottom:4, scrollbarWidth:'none' }}>
            {Object.values(CATEGORIAS).map(cat => (
              <div key={cat.id} onClick={() => nav(`/categoria/${cat.id}`)}
                style={{ flexShrink:0, display:'flex', flexDirection:'column', alignItems:'center', gap:4, cursor:'pointer' }}>
                <div style={{ width:54, height:54, borderRadius:'50%', background: cat.id==='bebidas'?'#FFF8DC': cat.id==='snacks'?'#FFF3EE': cat.id==='higiene'?'#F1F8E9': cat.id==='limpeza'?'#E3F2FD':'#F3E5F5',
                  border:`2px solid ${cat.cor}`, display:'flex', alignItems:'center', justifyContent:'center', fontSize:26 }}>
                  {cat.emoji}
                </div>
                <span style={{ fontSize:9, fontWeight:800, color:'#1A2E1F' }}>{cat.nome}</span>
              </div>
            ))}
          </div>
        </div>

        {/* favoritos */}
        <div style={{ padding:'14px 14px 0' }}>
          <div style={{ display:'flex', alignItems:'center', justifyContent:'space-between', marginBottom:10 }}>
            <span style={{ fontFamily:"'Fredoka One',cursive", fontSize:15, color:'#1A2E1F' }}>⭐ Seus favoritos</span>
          </div>
        </div>
        <div style={{ display:'flex', gap:10, overflowX:'auto', padding:'0 14px 4px', scrollbarWidth:'none' }}>
          {destaques.map(p => (
            <div key={p.id} style={{ flexShrink:0, width:120 }}>
              <ProductCard produto={p} />
            </div>
          ))}
        </div>

        {/* oferta relampago */}
        <div style={{ padding:'14px 14px 0' }}>
          <div style={{ display:'flex', alignItems:'center', justifyContent:'space-between', marginBottom:10 }}>
            <span style={{ fontFamily:"'Fredoka One',cursive", fontSize:15, color:'#1A2E1F' }}>⚡ Ofertas Relâmpago</span>
          </div>
          <div style={{ display:'grid', gridTemplateColumns:'1fr 1fr', gap:8 }}>
            {[
              { bg:'#E8622A', nome:'Cerveja Pack 12x',      label:'50% OFF',    img:'🍺' },
              { bg:'#2D5A3D', nome:'Arroz Camil 5kg',       label:'R$ 19,99',   img:'🌾' },
              { bg:'#1E3D2A', nome:'Chocolate Lacta',        label:'Leve 3 P 2', img:'🍫' },
              { bg:'#BA7517', nome:'Detergente Ypê Kit c/3', label:'R$ 5,00',    img:'🧴' },
            ].map((item,i) => (
              <div key={i} style={{ background:item.bg, borderRadius:14, padding:10, minHeight:80, position:'relative', overflow:'hidden', cursor:'pointer' }}>
                <p style={{ fontSize:10, fontWeight:900, color:'#fff', lineHeight:1.2, marginBottom:4, zIndex:1, position:'relative' }}>{item.nome}</p>
                <div style={{ fontFamily:"'Fredoka One',cursive", fontSize:16, color:'#fff', position:'relative', zIndex:1 }}>{item.label}</div>
                <span style={{ position:'absolute', right:-4, bottom:-4, fontSize:38, opacity:.25 }}>{item.img}</span>
              </div>
            ))}
          </div>
        </div>

        {/* pedido rapido */}
        <div style={{ padding:'14px 14px 0' }}>
          <div style={{ fontFamily:"'Fredoka One',cursive", fontSize:15, color:'#1A2E1F', marginBottom:10 }}>🛒 Pedido rápido</div>
          <div style={{ display:'grid', gridTemplateColumns:'1fr 1fr', gap:8 }}>
            {rapidos.map(p => <ProductCard key={p.id} produto={p} />)}
          </div>
        </div>
        <div style={{ height:16 }} />
      </div>

      <BottomNav />
    </div>
  )
}
